# Postgres
POSTGRES_USER=cart
POSTGRES_PASSWORD=cart
POSTGRES_DB=cart
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Composed for the backend (overrides DB__URL)
DB__URL=postgresql+asyncpg://cart:cart@postgres:5432/cart

# Redis
REDIS__URL=redis://redis:6379/0

# Auth — separate access + refresh secrets per backend/auth standard
JWT__ACCESS_SECRET=change-me-access-to-at-least-32-chars-long
JWT__REFRESH_SECRET=change-me-refresh-to-at-least-32-chars-long
JWT__ALGORITHM=HS256
JWT__ACCESS_TTL_SECONDS=900
JWT__REFRESH_TTL_SECONDS=604800

# Rate limiting (slowapi). storage_uri defaults to REDIS__URL when unset.
RATE_LIMIT__DEFAULT=300/minute
RATE_LIMIT__AUTH_LOGIN=5/minute
RATE_LIMIT__AUTH_REFRESH=5/minute

# Password policy
PASSWORD__MIN_LENGTH=8

# App
ENVIRONMENT=dev
APP_NAME=cart-calculator

# Frontend (Vite expects VITE_-prefixed vars)
VITE_API_BASE_URL=http://localhost/
